<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent" android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp" android:layout_marginVertical="8dp"
    app:cardCornerRadius="8dp" app:cardElevation="2dp">

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal" android:padding="16dp" android:gravity="center_vertical">
        <ImageView android:layout_width="40dp" android:layout_height="40dp"
            android:src="@android:drawable/ic_menu_myplaces" app:tint="#2196F3" android:layout_marginEnd="16dp"/>
        <TextView android:id="@+id/tvNombreCompletoEstudiante" android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:text="Nombre Apellido" android:textSize="18sp" android:textStyle="bold" android:textColor="?attr/colorOnSurface"/>

        <ImageButton android:id="@+id/btnEditarEstudiante" android:layout_width="40dp" android:layout_height="40dp"
            android:src="@android:drawable/ic_menu_edit" android:background="?attr/selectableItemBackgroundBorderless" app:tint="#FF9800"/>
        <ImageButton android:id="@+id/btnEliminarEstudiante" android:layout_width="40dp" android:layout_height="40dp"
            android:src="@android:drawable/ic_menu_delete" android:background="?attr/selectableItemBackgroundBorderless" app:tint="#F44336"/>

        <Button android:id="@+id/btnHacerTest" android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Test" android:backgroundTint="#4CAF50" android:visibility="gone"/>
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>